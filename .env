# ============================================
# 🔧 CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
APP_NAME="Correas Center"
APP_ENV=local
APP_KEY=base64:48jtDmxWWjaFTdU7rzvZ5WNLfMwxhCZq0VI3pP/kEyo=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/La_Paz
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# ============================================
# 🔐 SEGURIDAD Y MANTENIMIENTO
# ============================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Número de workers para el servidor PHP (solo en producción)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ============================================
# 📝 LOGS Y DEPURACIÓN
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# 🗄️ BASE DE DATOS
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=correas_center
DB_USERNAME=root
DB_PASSWORD=
# DB_PREFIX=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

# ============================================
# 📂 ALMACENAMIENTO DE ARCHIVOS
# ============================================
